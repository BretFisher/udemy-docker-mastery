# Super-linter configuration
# This is a teaching repo — only lint for natural language, shell, and YAML formatting
VALIDATE_BASH=true
VALIDATE_NATURAL_LANGUAGE=true
VALIDATE_YAML_PRETTIER=true

# it seems since we set above to true, these get messed up, so let's enable them like they default to
ENABLE_GITHUB_ACTIONS_STEP_SUMMARY=true
ENABLE_GITHUB_PULL_REQUEST_SUMMARY_COMMENT=true
SAVE_SUPER_LINTER_SUMMARY=true

